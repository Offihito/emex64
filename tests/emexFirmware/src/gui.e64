%define% FB_ENABLED     0x1FF00000
%define% FB_HEIGHT      0x1FF00001
%define% FB_WIDTH       0x1FF00003
%define% FB_FRAMEBUFFER 0x1FF00305
%define% FB_TEXT_COLOR  0xFF

section .data
    gui_line dw 0
    gui_column dw 0

;
; r0: character
;
_gui_putc:
    bz r0, .end

    ldw r1, gui_column
    ldw r2, gui_line
    
    mov r4, r1
    mov r5, r2
    
    inc r4
    
    mul r1, 8
    mul r2, 10
    
    cmp r0, '\n'
    be .newline

    stw gui_column, r4
    stw gui_line, r5

    cmp r0, 127
    bgt .end

    mov r4, _font_data
    mul r5, r0, 8
    add r4, r5

    clr r5
.row_loop:
    add r7, r4, r5
    ldb r6, r7

    clr r8

.col_loop:
    mov r9, 7
    sub r9, r8
    shr r10, r6, r9

    and r10, 1
    bz r10, .skip_pixel

    add r11, r2, r5
    cmp r11, 0

    blt .skip_pixel

    ldw r15, FB_HEIGHT
    ldw r16, FB_WIDTH
    
    cmp r11, r15
    bge .skip_pixel

    add r12, r1, r8
    cmp r12, 0

    blt .skip_pixel
    cmp r12, r16
    bge .skip_pixel

    mul r13, r11, r16
    add r13, r12
    add r13, FB_FRAMEBUFFER
    stb r13, FB_TEXT_COLOR
.skip_pixel:
    inc r8
    cmp r8, 8
    blt .col_loop

    inc r5
    cmp r5, 8
    blt .row_loop

.end:
    ret

.newline:
    ; reset column
    stw gui_column, 0

    ; how many glyphs fit?
    ldw r6, FB_HEIGHT
    div r6, 10
    dec r6

    cmp r5, r6
    bge .newline_scroll

    inc r5
    clr r4

    stw gui_line, r5

    ret

.newline_scroll:
    mov r0, 10
    b _scroll_up

_scroll_up:
    bz r0, .end

    ldw r1, FB_HEIGHT
    ldw r2, FB_WIDTH
    mov r3, FB_FRAMEBUFFER

    clr r4

.row_loop:
    mov r5, r1
    sub r5, r0
    cmp r4, r5
    bge .clear_bottom

    mov r6, r4
    add r6, r0

    mul r7, r4, r2
    mul r8, r6, r2

    add r9, r3, r7
    add r10, r3, r8

    mov r11, r2
.copy_loop:
    bz r11, .next_row
    ldb r12, r10
    stb r9, r12
    inc r9
    inc r10
    dec r11
    b .copy_loop

.next_row:
    inc r4
    b .row_loop

.clear_bottom:
    mov r4, r1
    sub r4, r0

.clear_loop:
    cmp r4, r1
    bge .end
        
    mul r7, r4, r2
    add r9, r3, r7

    mov r11, r2
.clear_row:
    bz r11, .next_clear
    stb r9, 0
    inc r9
    dec r11
    b .clear_row

.next_clear:
    inc r4
    b .clear_loop

.end:
    ret
