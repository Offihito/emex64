section .data
    exception_msg db "[!] panic because of exception code: 0x\0"

_exception_handler:
    bl _puts, exception_msg
    bl _putbase, cr2, 16
    bl _putc, '\n'

    ;
    ; no iret needed, platform is panicking
    ; but we need to hang so the user sees what
    ; happened.
    ;
    ; stb PLATFORM_PWR, 0
    ;

    b _fw_start.hang
