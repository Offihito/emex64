%include% <emex64.e64inc>

_ac97_init:
    mov  r1, AC97_BM_GLOB_CTRL_COLD_RST
    std  AC97_BM_GLOB_CTRL, r1

    stw  AC97_CODEC_RESET, 0

    mov  r2, AC97_POWER_TIMEOUT
.power_wait:
    ldw  r3, AC97_CODEC_POWERDOWN
    and  r3, AC97_PWR_ALL_READY
    mov  r4, AC97_PWR_ALL_READY
    cmp  r3, r4
    be   .power_ok
    dec  r2
    bz   r2, .power_fail
    b    .power_wait
.power_fail:
    mov  rr, 0
    not  rr
    wret
.power_ok:

    ldw  r3, AC97_CODEC_EXT_AUDIO_CTRL
    or   r3, AC97_EXT_CTRL_VRA
    stw  AC97_CODEC_EXT_AUDIO_CTRL, r3

    ;    r0 holds the caller-supplied rate
    stw  AC97_CODEC_PCM_DAC_RATE, r0

    stw  AC97_CODEC_MASTER_VOL, 0

    stw  AC97_CODEC_PCM_OUT_VOL, 0

    mov  r1, AC97_BM_CTRL_RESET
    stb  AC97_BM_PCMOUT_CTRL, r1

    mov  rr, 0
    wret


_ac97_play:
    ; make sure any previous run is stopped first
    mov  r2, AC97_BM_CTRL_RESET
    stb  AC97_BM_PCMOUT_CTRL, r2

    ; write BDL base address
    stq  AC97_BM_PCMOUT_BDL_BASE, r0

    ; write last valid index (lower 5 bits)
    and  r1, 0x1F
    stb  AC97_BM_PCMOUT_LVI, r1

    ; enable IOC interrupt and start DMA
    mov  r2, AC97_BM_CTRL_RUN
    or   r2, AC97_BM_CTRL_IOCE
    stb  AC97_BM_PCMOUT_CTRL, r2

    wret



_ac97_wait_irq:
    mov  r1, AC97_IRQ_TIMEOUT
.wait:
    ldw  r0, AC97_BM_PCMOUT_STATUS
    and  r0, AC97_BM_STATUS_BCIS
    bnz  r0, .got_irq
    dec  r1
    bz   r1, .timeout
    b    .wait
.got_irq:
    mov  rr, 0
    wret
.timeout:
    mov  rr, 0
    not  rr
    wret


_ac97_ack:
    ; clear BCIS in the channel status register (W1C)
    mov  r0, AC97_BM_STATUS_BCIS
    stw  AC97_BM_PCMOUT_STATUS, r0

    ; acknowledge interrupt in the INTC so the controller dequeues it
    mov  r0, IRQ_AC97
    stq  INTC_REG_ACK, r0

    wret
