; AC97 audio controller — MMIO constants
; Base: 0x002000000000E000  (MMIO_BASE + PAGE_SIZE*7)

%define% AC97_BASE                  0x0020000000010000

; codec registers (16-bit, AC97 2.3)
%define% AC97_CODEC_RESET           0x0020000000010000
%define% AC97_CODEC_MASTER_VOL      0x0020000000010008
%define% AC97_CODEC_HEADPHONE_VOL   0x0020000000010010
%define% AC97_CODEC_PCM_OUT_VOL     0x0020000000010018
%define% AC97_CODEC_RECORD_SELECT   0x0020000000010020
%define% AC97_CODEC_RECORD_GAIN     0x0020000000010028
%define% AC97_CODEC_GENERAL_PURPOSE 0x0020000000010030
%define% AC97_CODEC_POWERDOWN       0x0020000000010038
%define% AC97_CODEC_EXT_AUDIO_ID    0x0020000000010040
%define% AC97_CODEC_EXT_AUDIO_CTRL  0x0020000000010048
%define% AC97_CODEC_PCM_DAC_RATE    0x0020000000010050
%define% AC97_CODEC_PCM_ADC_RATE    0x0020000000010058
%define% AC97_CODEC_VENDOR_ID1      0x0020000000010060
%define% AC97_CODEC_VENDOR_ID2      0x0020000000010068

; AC97_CODEC_POWERDOWN bits
%define% AC97_PWR_ADC_READY     0x1
%define% AC97_PWR_DAC_READY     0x2
%define% AC97_PWR_ANL_READY     0x4
%define% AC97_PWR_VREF_UP       0x8
%define% AC97_PWR_ALL_READY     0xF

; bus-master registers
%define% AC97_BM_PCMOUT_BDL_BASE    0x0020000000010070
%define% AC97_BM_PCMOUT_CIV         0x0020000000010078
%define% AC97_BM_PCMOUT_LVI         0x0020000000010080
%define% AC97_BM_PCMOUT_STATUS      0x0020000000010088
%define% AC97_BM_PCMOUT_PICB        0x0020000000010090
%define% AC97_BM_PCMOUT_PIV         0x0020000000010098
%define% AC97_BM_PCMOUT_CTRL        0x00200000000100A0
%define% AC97_BM_GLOB_CTRL          0x00200000000100A8
%define% AC97_BM_GLOB_STATUS        0x00200000000100B0

; AC97_BM_PCMOUT_STATUS bits (W1C for interrupt bits)
%define% AC97_BM_STATUS_DCH         0x1
%define% AC97_BM_STATUS_CELV        0x2
%define% AC97_BM_STATUS_LVBCI       0x4
%define% AC97_BM_STATUS_BCIS        0x8
%define% AC97_BM_STATUS_FIFOE       0x10

; AC97_BM_PCMOUT_CTRL bits
%define% AC97_BM_CTRL_RUN           0x1
%define% AC97_BM_CTRL_RESET         0x2
%define% AC97_BM_CTRL_LVBIE         0x4
%define% AC97_BM_CTRL_FEIE          0x8
%define% AC97_BM_CTRL_IOCE          0x10

; AC97_BM_GLOB_CTRL bits
%define% AC97_BM_GLOB_CTRL_GIE      0x1
%define% AC97_BM_GLOB_CTRL_COLD_RST 0x2
%define% AC97_BM_GLOB_CTRL_WARM_RST 0x4

; BDL entry flags
%define% AC97_BDL_FLAG_IOC          0x8000
%define% AC97_BDL_FLAG_BUP          0x4000

%define% IRQ_AC97                   7

; AC97_CODEC_EXT_AUDIO_CTRL bits (used by ac97_init to enable VRA)
%define% AC97_EXT_CTRL_VRA          0x1     ; variable rate audio enable

; driver spin-loop limits
%define% AC97_POWER_TIMEOUT         0x100000    ; iterations waiting for power-ready
%define% AC97_IRQ_TIMEOUT           0x400000    ; iterations waiting for BCIS
